@using static Application.Queries.GetCart
@model GetCartResponse
@{
    ViewData["Title"] = "My Cart";
}

<h5 class="mb-4">My Cart</h5>

@if (Model == null || !Model.Items.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Your cart is empty.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark btn-sm">
            Shop Now
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th>Price</th>
                                <th>Qty</th>
                                <th>Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@item.ImageUrl"
                                                 style="width: 48px; height: 48px; object-fit: cover;"
                                                 class="rounded" />
                                            <span class="small fw-semibold">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td>₦@item.UnitPrice.ToString("N2")</td>
                                    <td style="width: 110px;">
                                        <form asp-action="UpdateItem" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <input type="number"
                                                   name="quantity"
                                                   value="@item.Quantity"
                                                   min="1"
                                                   class="form-control form-control-sm"
                                                   onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td>₦@item.SubTotal.ToString("N2")</td>
                                    <td>
                                        <form asp-action="RemoveItem" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="mb-3">Order Summary</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total</span>
                        <strong>₦@Model.TotalPrice.ToString("N2")</strong>
                    </div>
                    <hr />
                    <form asp-controller="Order" asp-action="PlaceOrder" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Delivery Address</label>
                            <textarea name="deliveryAddress"
                                  class="form-control form-control-sm"
                                  rows="3"
                                  placeholder="Enter your delivery address"
                                  required></textarea>
                        </div>
                        <button type="submit" class="btn btn-dark w-100">
                            Place Order
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}