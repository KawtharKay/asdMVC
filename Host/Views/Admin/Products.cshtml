@using static Application.Queries.GetAllProducts
@model IEnumerable<GetAllProductsResponse>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">Products</h5>
    <a asp-action="CreateProduct" class="btn btn-dark btn-sm">+ Add Product</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Product</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center gap-2">
                                <img src="@p.ImageUrl"
                                     style="width: 40px; height: 40px; object-fit: cover;"
                                     class="rounded" />
                                <span class="small fw-semibold">@p.Name</span>
                            </div>
                        </td>
                        <td class="small text-muted">@p.Sku</td>
                        <td class="small">@p.CategoryName</td>
                        <td class="small fw-semibold">₦@p.Price.ToString("N2")</td>
                        <td class="small">@p.StockQuantity</td>
                        <td>
                            <span class="badge @(!p.IsInStock ? "bg-danger" : p.IsLowStock ? "bg-warning text-dark" : "bg-success")">
                                @(!p.IsInStock ? "Out of Stock" : p.IsLowStock ? "Low Stock" : "In Stock")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="EditProduct"
                                   asp-route-id="@p.Id"
                                   class="btn btn-outline-dark btn-sm">Edit</a>
                                <form asp-action="DeleteProduct" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Delete this product?')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>