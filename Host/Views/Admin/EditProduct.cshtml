@using static Application.Queries.GetProductById
@using static Application.Queries.GetAllCategories
@model GetProductByIdResponse
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as IEnumerable<GetAllCategoriesResponse>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">Edit Product</h5>
    <a asp-action="Products" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="EditProduct" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Name</label>
                        <input name="Name" value="@Model.Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Price (₦)</label>
                        <input name="Price" value="@Model.Price"
                               class="form-control" type="number" step="0.01" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Category</label>
                        <select name="CategoryId" class="form-select">
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    if (cat.Name == Model.CategoryName)
                                    {
                                        <option value="@cat.Id" selected>@cat.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label small fw-semibold">Stock</label>
                            <input name="StockQuantity" value="@Model.StockQuantity"
                                   class="form-control" type="number" required />
                        </div>
                        <div class="col">
                            <label class="form-label small fw-semibold">Low Stock Threshold</label>
                            <input name="LowStockThreshold" value="@Model.LowStockThreshold"
                                   class="form-control" type="number" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Image URL</label>
                        <input name="ImageUrl" value="@Model.ImageUrl" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Update Product</button>
                </form>
            </div>
        </div>
    </div>
</div>