@using static Application.Queries.GetAllOrders
@model IEnumerable<GetAllOrdersResponse>
@{
    ViewData["Title"] = "Orders";
}

<h5 class="mb-4">All Orders</h5>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Order No</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="ps-3 fw-semibold small">@o.OrderNo</td>
                        <td>
                            <p class="mb-0 small fw-semibold">@o.CustomerName</p>
                            <small class="text-muted">@o.CustomerEmail</small>
                        </td>
                        <td class="small text-muted">
                            @o.DateCreated.ToString("dd MMM yyyy")
                        </td>
                        <td class="small fw-semibold">₦@o.TotalAmount.ToString("N2")</td>
                        <td>
                            <span class="badge @GetStatusBadge(o.Status)">@o.Status</span>
                        </td>
                        <td>
                            <a asp-action="OrderDetails"
                               asp-route-id="@o.OrderId"
                               class="btn btn-sm btn-outline-dark">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-info text-dark",
        "Shipped" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
}