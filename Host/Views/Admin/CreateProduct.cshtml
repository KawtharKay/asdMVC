@using static Application.Commands.CreateProduct
@using static Application.Queries.GetAllCategories
@model CreateProductCommand
@{
    ViewData["Title"] = "Add Product";
    var categories = ViewBag.Categories as IEnumerable<GetAllCategoriesResponse>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">Add Product</h5>
    <a asp-action="Products" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="CreateProduct" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-semibold">Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sku" class="form-label small fw-semibold">SKU</label>
                        <input asp-for="Sku" class="form-control" />
                        <span asp-validation-for="Sku" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label small fw-semibold">Price (₦)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label small fw-semibold">Category</label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">-- Select --</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label asp-for="StockQuantity" class="form-label small fw-semibold">Stock</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col">
                            <label asp-for="LowStockThreshold" class="form-label small fw-semibold">Low Stock Threshold</label>
                            <input asp-for="LowStockThreshold" class="form-control" type="number" />
                            <span asp-validation-for="LowStockThreshold" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label small fw-semibold">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Save Product</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}