@using static Application.Queries.GetAllCustomers
@model IEnumerable<GetAllCustomersResponse>
@{
    ViewData["Title"] = "Customers";
}

<h5 class="mb-4">Customers</h5>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Orders</th>
                    <th>Wallet</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="ps-3 fw-semibold small">@c.Name</td>
                        <td class="small text-muted">@c.Email</td>
                        <td class="small">@c.Phone</td>
                        <td class="small">@c.TotalOrders</td>
                        <td class="small fw-semibold">₦@c.WalletBalance.ToString("N2")</td>
                        <td class="small text-muted">
                            @c.DateJoined.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <a asp-action="CustomerDetails"
                               asp-route-id="@c.CustomerId"
                               class="btn btn-sm btn-outline-dark">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>