@using static Application.Queries.GetCustomerById
@model GetCustomerByIdResponse
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">@Model.Name</h5>
    <a asp-action="Customers" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="mb-3">Customer Info</h6>
                <p class="small mb-2">
                    <span class="text-muted">Email</span><br />@Model.Email
                </p>
                <p class="small mb-2">
                    <span class="text-muted">Phone</span><br />@Model.Phone
                </p>
                <p class="small mb-2">
                    <span class="text-muted">Address</span><br />@Model.Address
                </p>
                <p class="small mb-3">
                    <span class="text-muted">Joined</span><br />
                    @Model.DateJoined.ToString("dd MMM yyyy")
                </p>
                <hr />
                <p class="small text-muted mb-1">Wallet Balance</p>
                <h5 class="fw-bold text-success">₦@Model.WalletBalance.ToString("N2")</h5>
                <p class="small mb-0">
                    <span class="text-muted">Total Orders:</span>
                    <strong>@Model.TotalOrders</strong>
                </p>
            </div>
        </div>
    </div>
</div>