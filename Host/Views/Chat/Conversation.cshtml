@using static Application.Queries.GetConversationMessages
@model IEnumerable<GetConversationMessagesResponse>
@{
    ViewData["Title"] = "Chat";
    var conversationId = ViewBag.ConversationId;
    var currentUserId = ViewBag.CurrentUserId;
    var currentUserName = ViewBag.CurrentUserName as string;
}

<div class="card shadow-sm border-0" style="height: 580px; display: flex; flex-direction: column;">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
        <span class="fw-semibold small">Support Chat</span>
        <a asp-action="Index" class="text-white text-decoration-none small">← Back</a>
    </div>

    <div class="card-body overflow-auto flex-grow-1 p-3 bg-light" id="msgBox">
        @foreach (var msg in Model)
        {
            var isMe = msg.SenderId.ToString() == currentUserId?.ToString();
            <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-2">
                <div class="px-3 py-2 rounded-3 small @(isMe ? "bg-dark text-white" : msg.IsAi ? "bg-white border" : "bg-white border")"
                     style="max-width: 65%;">
                    @if (!isMe)
                    {
                        <p class="fw-bold mb-1 small" style="font-size: 0.75rem;">@msg.SenderName</p>
                    }
                    <p class="mb-0">@msg.Content</p>
                    <p class="mb-0 opacity-50" style="font-size: 0.7rem;">
                        @msg.SentAt.ToString("hh:mm tt")
                    </p>
                </div>
            </div>
        }
    </div>

    <div class="card-footer bg-white border-0 p-2">
        <div class="input-group">
            <input type="text"
                   id="msgInput"
                   class="form-control form-control-sm"
                   placeholder="Type a message..."
                   onkeypress="handleKey(event)" />
            <button class="btn btn-dark btn-sm" onclick="sendMsg()">Send</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const convId = '@conversationId';
        const myId = '@currentUserId';
        const myName = '@currentUserName';
        const box = document.getElementById('msgBox');

        const conn = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .build();

        conn.on('ReceiveMessage', msg => appendMsg(msg));

        conn.start().then(() => conn.invoke('JoinConversation', convId));

        function appendMsg(msg) {
            const isMe = msg.senderId === myId;
            const div = document.createElement('div');
            div.className = `d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-2`;
            div.innerHTML = `
                <div class="px-3 py-2 rounded-3 small ${isMe ? 'bg-dark text-white' : 'bg-white border'}"
                     style="max-width: 65%;">
                    ${!isMe ? `<p class="fw-bold mb-1" style="font-size:.75rem">${msg.senderName}</p>` : ''}
                    <p class="mb-0">${msg.content}</p>
                </div>`;
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function sendMsg() {
            const input = document.getElementById('msgInput');
            const content = input.value.trim();
            if (!content) return;

            fetch('/Chat/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ conversationId: convId, content })
            })
            .then(r => r.json())
            .then(d => { if (d.success) input.value = ''; });
        }

        function handleKey(e) {
            if (e.key === 'Enter') sendMsg();
        }

        box.scrollTop = box.scrollHeight;
    </script>
}