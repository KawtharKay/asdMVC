@using static Application.Queries.GetMyConversations
@model IEnumerable<GetMyConversationsResponse>
@{
    ViewData["Title"] = "Support Chat";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">My Conversations</h5>
    <form asp-action="Start" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-dark btn-sm">+ New Chat</button>
    </form>
</div>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">No conversations yet.</p>
    </div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var c in Model)
        {
            <a asp-action="Conversation"
               asp-route-id="@c.ConversationId"
               class="list-group-item list-group-item-action border-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-0 fw-semibold small">@c.Title</p>
                        <p class="mb-0 text-muted small text-truncate" style="max-width: 300px;">
                            @c.LastMessage
                        </p>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">
                            @c.LastMessageAt.ToString("dd MMM, hh:mm tt")
                        </small>
                        <span class="badge @(c.IsHandedOffToHuman ? "bg-success" : "bg-secondary")">
                            @(c.IsHandedOffToHuman ? "Agent" : "AI")
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>
}