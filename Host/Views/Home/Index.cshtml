@using static Application.Queries.GetAllProducts
@using static Application.Queries.GetAllCategories
@model IEnumerable<GetAllProductsResponse>
@{
    ViewData["Title"] = "Home";
    var categories = ViewBag.Categories as IEnumerable<GetAllCategoriesResponse>;
    var selectedCategory = ViewBag.SelectedCategory as Guid?;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0">Products</h5>
    <div class="d-flex flex-wrap gap-1">
        <a asp-action="Index"
           class="btn btn-sm @(selectedCategory == null ? "btn-dark" : "btn-outline-secondary")">
            All
        </a>
        @if (categories != null)
        {
            @foreach (var cat in categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@cat.Id"
                   class="btn btn-sm @(selectedCategory == cat.Id ? "btn-dark" : "btn-outline-secondary")">
                    @cat.Name
                </a>
            }
        }
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">No products found.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-4 g-3">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@product.ImageUrl"
                         class="card-img-top"
                         alt="@product.Name"
                         style="height: 190px; object-fit: cover;" />
                    <div class="card-body pb-1">
                        <p class="mb-1 fw-semibold">@product.Name</p>
                        <p class="text-muted small mb-1">@product.CategoryName</p>
                        <p class="fw-bold mb-2">₦@product.Price.ToString("N2")</p>
                        @if (!product.IsInStock)
                        {
                            <span class="badge bg-danger">Out of Stock</span>
                        }
                        else if (product.IsLowStock)
                        {
                            <span class="badge bg-warning text-dark">
                                Low Stock
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">In Stock</span>
                        }
                    </div>
                    <div class="card-footer bg-white border-0 pt-1">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@product.Id"
                           class="btn btn-outline-dark btn-sm w-100">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}