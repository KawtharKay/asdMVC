@{
    ViewData["Title"] = "Verify Email";
    var email = ViewBag.Email as string;
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h4 class="mb-2">Verify Your Email</h4>
                <p class="text-muted small mb-4">
                    We sent a 4-digit code to <strong>@email</strong>
                </p>

                <form asp-action="VerifyEmail" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@email" />

                    <div class="mb-3">
                        <input name="token"
                               class="form-control form-control-lg text-center"
                               maxlength="4"
                               placeholder="0000"
                               style="letter-spacing: 12px; font-size: 1.8rem;" />
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Verify</button>
                </form>

                <form asp-action="ResendVerification" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@email" />
                    <button type="submit" class="btn btn-link btn-sm p-0 text-muted">
                        Didn't receive it? Resend code
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>