@using static Application.Commands.ResetPassword
@model ResetPasswordCommand
@{
    ViewData["Title"] = "Reset Password";
    var email = ViewBag.Email as string;
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="mb-4">Reset Password</h4>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Email" value="@email" />

                    <div class="mb-3">
                        <label class="form-label">Reset Code</label>
                        <input asp-for="Token"
                               class="form-control text-center"
                               maxlength="4"
                               placeholder="0000"
                               style="letter-spacing: 12px; font-size: 1.5rem;" />
                        <span asp-validation-for="Token" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        Reset Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}