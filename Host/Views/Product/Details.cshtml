@using static Application.Queries.GetProductById
@model GetProductByIdResponse
@{
    ViewData["Title"] = Model.Name;
}

<div class="row g-4">
    <div class="col-md-5">
        <img src="@Model.ImageUrl"
             class="img-fluid rounded shadow-sm"
             alt="@Model.Name"
             style="width: 100%; max-height: 400px; object-fit: cover;" />

        @if (!string.IsNullOrEmpty(Model.QrCodeImagePath))
        {
            <div class="mt-3">
                <p class="text-muted small mb-1">Product QR Code</p>
                <img src="@Model.QrCodeImagePath"
                     style="width: 90px;"
                     alt="QR Code" />
            </div>
        }
    </div>

    <div class="col-md-7">
        <p class="text-muted small mb-1">@Model.CategoryName</p>
        <h3 class="fw-bold">@Model.Name</h3>
        <p class="text-muted small">SKU: @Model.Sku</p>
        <h4 class="fw-bold my-3">₦@Model.Price.ToString("N2")</h4>

        @if (!Model.IsInStock)
        {
            <span class="badge bg-danger mb-3 d-block w-auto" style="width: fit-content;">
                Out of Stock
            </span>
        }
        else if (Model.IsLowStock)
        {
            <span class="badge bg-warning text-dark mb-3">
                Only @Model.StockQuantity left!
            </span>
        }
        else
        {
            <span class="badge bg-success mb-3">In Stock</span>
        }

        @if (User.Identity!.IsAuthenticated && Model.IsInStock)
        {
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="d-flex align-items-center gap-3 mb-3">
                    <label class="form-label mb-0 fw-semibold">Qty</label>
                    <input type="number"
                           name="quantity"
                           value="1" min="1"
                           max="@Model.StockQuantity"
                           class="form-control"
                           style="width: 90px;" />
                </div>
                <button type="submit" class="btn btn-dark px-4">
                    Add to Cart
                </button>
            </form>
        }
        else if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Auth" asp-action="Login"
               class="btn btn-outline-dark mt-3">
                Login to Purchase
            </a>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        ← Back
    </a>
</div>